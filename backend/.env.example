# Database URL (PostgreSQL via Neon)
DATABASE_URL=postgresql+psycopg2://user:password@host/database?sslmode=require

# JWT Configuration
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256

# Encryption Key (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_SECRET_KEY=change-this-to-a-fernet-key
